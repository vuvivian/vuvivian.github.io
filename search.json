                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        [{"title":"日常小结/js使用filter递归过滤树形结构数组","date":"2020-03-20T07:13:24.831Z","url":"/2020/03/20/日常小结/js使用filter递归过滤树形结构数组/"},{"title":"日常小结/遍历树形结构的每个子节点","date":"2020-03-20T07:03:20.780Z","url":"/2020/03/20/日常小结/遍历树形结构的每个子节点/","content":"定义了一个按钮的列表，列表是一个树形结构，现在有个问题是，需要遍历树形的每个子节点，给每个子节点生成一个btnId，最终返回一个key为btnId, 值为子节点数据的对象。数据结构如下：执行代码：执行结果："},{"title":"odoo源码/按钮/按钮的事件处理","date":"2020-03-17T02:35:40.243Z","url":"/2020/03/17/odoo源码/按钮/按钮的事件处理/","content":"List新建list 中header 中的object   _addOnClickAction        1. 存在confirm属性        2. special === ‘cancle’ =》 _callButtonAction        2. !special || special === ‘save’   =》 saveAndExecuteAction"},{"title":"odoo源码/qweb","date":"2020-03-12T11:47:50.562Z","url":"/2020/03/12/odoo源码/qweb/","content":"　循环计算切片: t-foreach=”record.message_follower_ids.raw_value.slice(0, 3)” 还可以rec_index 从0开始循环索引rec_size  要循环的记录集大小rec_first  第一个元素rec_last   最后一个元素rec_even   index为偶数时为真rec_odd    index为奇数时为真rec_parity  是偶数和奇数rec_all  表示循环结束的标识rec_value 循环一个字典时，的键的值"},{"title":"常用工具方法","date":"2020-03-10T15:10:03.478Z","url":"/2020/03/10/常用工具方法/","content":"1. all如果数组所有的元素满足函数条件，返回true，调用时，如果省略第二个参数，则默认传递布尔值2. allEqual判断数组中的元素是否都相等3. approximatelyEqual此代码示例检查两个数字是否近似相等，差异值可以通过传餐的形式进行设置4. arrayToCSV将没有逗号或双引号的元素转换成带有逗号分隔符的字符串即CSV格式识别的格式5. arrayToHtmlList"},{"title":"react/react hook","date":"2020-03-10T14:16:42.575Z","url":"/2020/03/10/react/react hook/","content":"函数式组件使用函数式组件时需要将组件申明为 React.FC类型，也就是Function Component的意思，props也需要申明各个参数的类型，并通过泛型传递给React.FC. 还支持children的传入useState优化了this.state 和 this.setState ,不用频繁使用this.， 参数可以为基本类型，也可以为对象类型，为对象类型的时候，setXXX并不会像this.setState一样合并旧的状态，而是完全替代了旧的状态，如果要实现合并的话，需要使用扩展运算符， 如下面第二句useEffect可以将useEffect看作 componentDidMount, componentDidUpdate 和 componentWillUnmount三个函数的组合useMemouseCallbackuseReduceruseContext"},{"title":"odoo源码/control_panel","date":"2020-03-10T05:44:59.984Z","url":"/2020/03/10/odoo源码/control_panel/","content":"结构区域区分"},{"title":"odoo源码/按钮/form渲染header按钮","date":"2020-03-05T04:50:44.139Z","url":"/2020/03/05/odoo源码/按钮/form渲染header按钮/","content":"执行逻辑顺序"},{"title":"odoo源码/按钮/自定义按钮说明","date":"2020-03-04T15:05:21.576Z","url":"/2020/03/04/odoo源码/按钮/自定义按钮说明/","content":"buttonspack​    预制按钮  （普通按钮在对应的视图xml中，sidebar在对应的renderSiderbar中）button 参数buttongroup"},{"title":"odoo源码/odoo 校验rng","date":"2020-03-04T02:11:46.458Z","url":"/2020/03/04/odoo源码/odoo 校验rng/"},{"title":"odoo源码/odoo异常处理","date":"2020-03-03T04:53:43.360Z","url":"/2020/03/03/odoo源码/odoo异常处理/","content":"后台异常抛错方式exception_type异常类型   except_ormaccess_denied: _lt(“Access Denied”),access_error: _lt(“Access Error”),except_orm: _lt(“Global Business Error”),missing_error: _lt(“Missing Record”),user_error: _lt(“User Error”),validation_error: _lt(“Validation Error”),warning: _lt(“Warning”),后台异常管理odoo/exceptions.py返回数据格式：web 异常处理addons/web/static/src/js/services/crash_manager.jsrpc_error中处理数据格式show_warning中打开提示信息"},{"title":"第一个应用","date":"2020-03-01T13:47:00.000Z","url":"/2020/03/01/odoo源码/（二）创建第一个应用/","content":"Odoo遵循 MVC-like 架构设计M模型层，定义app的数据结构，描述业务对象，模型是从 Odoo 模板类派生的 Python 类实现的。 它们直接转换为数据库对象，Odoo在安装或升级模块时会自动处理。负责此机制的是对象关系模型（ORM）。V视图层，描述用户界面，是使用XML定义的，它被Web客户端框架用来转换成数据感知的HTML视图，当模块安装或升级时，xml数据文件中的这些用户接口定义就会被加载到数据库中。所有的视图都存储在数据库中，在 ir.ui.view模式下.C 控制器层，支持应用的业务逻辑在启动服务器实例时，附加选项–dev=all。Odoo模块权限管理一般odoo管理权限会放在security文件夹里、一个csv和一个xml重要的两个文件    1. security.xml：id可以看着来写，ref-=“中的内容是继承第一个id”，仔细观察下就会发现规律。    2. ir.model.access.csv：文件名与要加载的数据的模块名相对应，并且该文件的第一行包含列名称。以下是我们的 CSV 文件中提供的列:        *    id是记录的外部标识符 (也称为 XML ID)。在我们的模块中它应该是唯一。        *    name是一个描述标题。它只是内容展示，在模块中最好也保持其唯一性。官方模块通常使用模型名称和组的圆点分隔的字符串。遵循此约定，我们使用 todo.task.user        *    model_id 是该模型的外部标识符。ORM给模型自动生成的 O的 XML Id︰ 如 todo.task，该标识符是model_todo_task        *    group_id标识授予权限的访问组。最重要的一点是提供定义它的模块名前缀。比如员工组，它的标识符为base.group_user。        *    perm字段标记授予的读, 写, 创建，或删除权限。    3. 不能忘记将引用添加到文件manifest.py的data属性中。 security/ir.model.access.csv’，    4. 创建模型层应用程序的主要功能有：用于描述的简单文本字段、用于将其标记为完成的复选框、最后需要添加一个按钮来清除已完成任务的旧的待办事项列表。可以使用技术菜单查看新创建的模型。在顶部菜单设置中，转到技术|数据库结构|模型，在列表中搜索todo.task模型，并单击它以查看其定义：加入自动化测试Odoo支持使用两种方式来描述测试: 使用 YAML 数据文件或使用 Python 代码、基于 Unittest2 库。 YAML 测试是一种遗留下来的旧老版本, 不建议使用。 我们会更乐意使用 Python 测试并将添加基本的测试实例到我门的模块。测试代码文件必须用test_开头 , 并且从tests/init.py文件导入。 但 测试的 目录(或 Python 的子模块)不应从模块的顶部的init.py导入， 因为仅在测试的执行的时候会自动被发现并装载。运行我们的测试。 当我们在安装模，可以添加 –test-enable选项:   $ ./odoo-bin -d todo -i todo_app –test-enable创建视图层用户界面接口，包括菜单和动作，存储在数据库表中。添加一个菜单选项来打开To-do Task模型添加id属性也称为XML ID，它用于唯一标识模块内的每个数据元素，并且可以由其他元素使用来引用它。添加到manifest.py文件的data属性中。创建Form视图要向模块添加视图，我们在XML文件中声明一个描述视图的元素，该模块在安装模块时将被加载到数据库中。todo_view.xmlform视图下的标签headersheetgroup添加动作按钮Form视图可以添加按钮以完成特定动作。这些按钮可以打开一个新的包含Form表单的窗口或运行定义在模块中的Python函数。string:展示在按钮上的文本type:动作的类型（执行的操作）name：定义的动作（操作的标识符）class：一个可选的属性，用于展示Css样式，同HTML规则一样创建Tree视图创建Search视图元素定义了在搜索框中输入时也能搜索的字段。 元素添加了预定义的过滤条件(过滤条件可以通过用户点击来切换），是使用特定语法来定义的。业务逻辑层  Toggle Done按钮的操作将非常简单：只需切换Is Done? 标记。对于记录上的逻辑，使用@api.multi装饰器。 这里，self将表示一个记录集，然后我们应该遍历每个记录。AttributeError: module ‘odoo.api’ has no attribute ‘multi’        After searching in github found that ‘multi’ is removed from Odoo 13.0 as it will be default."},{"title":"button","date":"2020-03-01T13:47:00.000Z","url":"/2020/03/01/odoo源码/按钮/按钮/","content":"类型按钮ControlPanel属性toolbar是如何加载到o_cp_left的   abstract.view. &amp;&amp;. basic.view初始了按钮的相关参数ControlPanelRenderer中定义node对象，指定button的dom，定义为$buttonsAbstractController中执行_renderControlPanelElementsListController中renderButtons，this.$button =  qweb.render(‘listView.buttons”‘)ListController中renderSidebarappendto $nodeListController中 _toggleCreateButton 根据this.renderer.isEditable() &amp;&amp; state.groupedBy.length &amp;&amp; state.data.length;确定创建按钮的现实与隐藏destroy动作按钮如何根据选择的数量显示与隐藏的ListController中_onSelectionChanged_toggleSidebarthis.sidebar.do_toggle预制按钮的显隐控制 预制按钮：存在activeActions中： 创建 保存 复制 导出 取消不同按钮的处理"},{"title":"环境搭建","date":"2020-02-29T13:47:00.000Z","url":"/2020/02/29/odoo源码/（一）环境搭建/","content":"基本环境及安装软件查看环境  python 3.8报错，使用的是3.7postgres数据库安装利用pycharm环境启动程序搭建环境中出现的问题及方案pip安装python包出错：Could not find a version that satisfies the requirement skimage (from versions: ):  Could not find a version that satisfies the requirement pywin32 (from versions: ) No matching distribution found for pywin32解决方案：这是因为网络的问题，需要使用国内的镜像源来加速,比如豆瓣源  命令改为：    pip install scikit-image -i  –trusted-host pypi.douban.com    或者    pip3 install scikit-image -i  –trusted-host pypi.douban.com  最后成功安装：No module named ‘psycopg2’Database creation error: permission denied to create database  解决方案:给角色赋权：CREATE ROLE odoo WITH SUPERUSER LOGIN PASSWORD ‘odoo’;socket.error: [Errno 48] Address already in use   解决方案:  1. sudo lsof -i:8069   2. kill {PID}参看资料 "},{"title":"odoo源码/全局概览","date":"2020-02-27T15:23:20.610Z","url":"/2020/02/27/odoo源码/全局概览/"},{"title":"预备篇","date":"2020-02-21T02:14:45.000Z","url":"/2020/02/21/vue源码/预备篇/","content":""},{"title":"koa路由","date":"2019-12-19T15:52:30.090Z","url":"/2019/12/19/koa路由/","content":"koa路由需要安装koa-router来处理相关路由引入并实例化配置路由： router.get()启动路由：app.use()获取get传值获取post传值"},{"title":"关于异步","date":"2019-12-15T13:47:00.000Z","url":"/2019/12/15/关于异步/","content":"程序执行顺序回调函数获取异步方法中的数据promise 处理异步async 与 awaitasync让方法变成异步,返回值是一个promise获取async异步方法里面的数据的第一种方法await是等待异步方法执行完成, 是获取async异步方法里面的数据的第二种方法，但是必须用在异步方法里面await 阻塞的功能，将异步改为同步async 定义的方法返回的是Promise对象"},{"title":"odoo模块资源","date":"2019-12-15T13:47:00.000Z","url":"/2019/12/15/odoo源码/资源推荐/","content":"apps.odoo.com上的Odoo应用商店是一个可以下载并安装在系统上的模块目录。Odoo社区协会（OCA）协调社区贡献，并在GitHub上维护了很多模块存储库。"},{"title":"vue服务器端渲染的简单实现","date":"2019-12-15T13:47:00.000Z","url":"/2019/12/15/ssr的了解/vue服务器端渲染的简单实现/","content":"一个简单的服务器渲染的小栗子vue 的服务器端渲染参考资料： []"},{"title":"服务器端渲染介绍","date":"2019-12-15T13:47:00.000Z","url":"/2019/12/15/ssr的了解/服务器端渲染与客户端渲染的区别/","content":"什么是服务器端渲染服务器端渲染就海思后端将数据与页面元素进行结合，将完成的html页面直接返回给浏览器。什么事客户端渲染客户端渲染是数据由前台通过js将ajax动态获取的数据与dom元素进行结合，然后展示在网页上。服务器端和客户端的比较服务器端渲染需要消耗更多的服务器资源客户端渲染可以静态资源部署到cdn上，实现高并发服务器端渲染对SEO更友好参考："},{"title":"Nuxt的使用","date":"2019-12-15T13:47:00.000Z","url":"/2019/12/15/ssr的了解/nuxt框架了解/Nuxt的使用/","content":"npm5.2.0 引入了npx，使用npx可以提升开发者使用命令行的命令行工具的体验nuxt 安装目录结构assets： 静态资源，会通过wenbpack进行编译components： 组件layouts：整体布局，文件名称不可更改middleware： 中间件处理，比如权限验证pages：N多的页面plugins：存放插件，比如UI插件 Elementuistatic：静态资源，不会通过webpack进行构建，直接通过服务器向外暴漏store：全局状态管理 vuexnuxt.config.js：nuxt配置文件package.json: 项目描述文件nuxt常用配置文件nuxt路由根据pages下的文件路径自动生成路由首页的生成在 全局layout下的 配置页面跳转：首页动态跳转，在文件名中用 _params 来区别嵌套路由  需要单文件组件和同名的文件夹过渡动画  Nuxt.js 默认使用的过渡效果名称为 page中间件 是一个function视图做一些头部信息的配置404 504页面定制布局调整异步数据asyncData资源文件插件命令和部署"},{"title":"微信公众号分类","date":"2019-12-08T14:09:17.000Z","url":"/2019/12/08/微信公众号分类/","content":"分类订阅号为媒体和个人提供一种信息传播方式，主要偏于为用户传达资讯（类似报纸杂志），主要的定位是阅读，每天可以群发1条消息；服务号为企业，政府或组织提供对用户进行服务，主要偏于服务交互（类似银行提供服务查询），每个月只可群发4条消息；企业微信为企业，政府，事业单位，实现生产管理和协作运营的移动化，主要用于公司内部通讯使用，旨在为用户提供移动办公，需要先有成员的通讯信息验证才可以关注成功企业微信；还有一个比较明显的区别就是，订阅号都是存放在一个名叫订阅号的文件夹中，点开才能看到所有关注过的订阅号，但是服务号却和好友一样直接就显示在聊天列表中。这个大家打开微信客户端便能看到。"},{"title":"常用css属性","date":"2019-12-08T13:48:51.443Z","url":"/2019/12/08/常用css属性/","content":"[x]阴影[box-shadow:属性用于在元素的框架上添加阴影效果 ，该属性可设置的值包括，X偏移，Y偏移，阴影模糊半径，阴影扩散半径，和阴影颜色并以多个逗号分隔。[x][反射]box-reflect:属性用于在某一个方向反射元素的内容。[x]transition：属性是 transition-property，transition-duration，transition-timing-function 和 transition-delay 的一个简写属性。[x]transform：属性定义了一系列应用于元素和元素子元素的变换规则集合。"},{"title":"CSS+伪元素 实现提示工具Tooltips","date":"2019-12-04T14:56:42.000Z","url":"/2019/12/04/CSS-伪元素-实现提示工具Tooltips/","content":""},{"title":"JavaScript中的prototype属性","date":"2019-12-01T13:24:11.000Z","url":"/2019/12/01/JavaScript中的prototype属性/","tags":["JavaScript"],"content":"定义prototype 属性允许您向对象添加属性和方法，Prototype 是全局属性，并适用于所有的 Javascript 对象。用法object.prototype.name=value注意prototype属性是函数所独有的，由于在js中一切皆对象，函数也不例外，故这并非和其定义相矛盾。由来所有的实例对象都可以继承构造函数中的属性和方法,但是，在同一个对象的实例之间却无法共享属性。如下代码：为了解决构造函数的对象实例之间无法共享属性的缺点，js提供了prototype属性。如下代码："},{"title":"来自React的灵魂拷问","date":"2019-11-02T09:34:05.000Z","url":"/2019/11/02/来自React的灵魂拷问/","tags":["react"],"content":"什么是纯函数箭头函数的作用有无状态组件的区别React中的合成事件什么情况下应该使用引用（ref）React中如何创建表单受控和非受控组件的区别高阶组件是什么，怎么用什么是纯组件使用MVC有什么问题FluxRedux Reducer 以及数据流动"}]