                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    [{"title":"koa路由","date":"2019-12-19T15:52:30.090Z","url":"/2019/12/19/koa路由/","content":"koa路由需要安装koa-router来处理相关路由引入并实例化配置路由： router.get()启动路由：app.use()获取get传值获取post传值"},{"title":"关于异步","date":"2019-12-15T13:47:00.000Z","url":"/2019/12/15/关于异步/","content":"程序执行顺序回调函数获取异步方法中的数据promise 处理异步async 与 awaitasync让方法变成异步,返回值是一个promise获取async异步方法里面的数据的第一种方法await是等待异步方法执行完成, 是获取async异步方法里面的数据的第二种方法，但是必须用在异步方法里面await 阻塞的功能，将异步改为同步async 定义的方法返回的是Promise对象"},{"title":"微信公众号分类","date":"2019-12-08T14:09:17.000Z","url":"/2019/12/08/微信公众号分类/","content":"分类订阅号为媒体和个人提供一种信息传播方式，主要偏于为用户传达资讯（类似报纸杂志），主要的定位是阅读，每天可以群发1条消息；服务号为企业，政府或组织提供对用户进行服务，主要偏于服务交互（类似银行提供服务查询），每个月只可群发4条消息；企业微信为企业，政府，事业单位，实现生产管理和协作运营的移动化，主要用于公司内部通讯使用，旨在为用户提供移动办公，需要先有成员的通讯信息验证才可以关注成功企业微信；还有一个比较明显的区别就是，订阅号都是存放在一个名叫订阅号的文件夹中，点开才能看到所有关注过的订阅号，但是服务号却和好友一样直接就显示在聊天列表中。这个大家打开微信客户端便能看到。"},{"title":"常用css属性","date":"2019-12-08T13:48:51.443Z","url":"/2019/12/08/常用css属性/","content":"[x]阴影[box-shadow:属性用于在元素的框架上添加阴影效果 ，该属性可设置的值包括，X偏移，Y偏移，阴影模糊半径，阴影扩散半径，和阴影颜色并以多个逗号分隔。[x][反射]box-reflect:属性用于在某一个方向反射元素的内容。[x]transition：属性是 transition-property，transition-duration，transition-timing-function 和 transition-delay 的一个简写属性。[x]transform：属性定义了一系列应用于元素和元素子元素的变换规则集合。"},{"title":"CSS+伪元素 实现提示工具Tooltips","date":"2019-12-04T14:56:42.000Z","url":"/2019/12/04/CSS-伪元素-实现提示工具Tooltips/","content":""},{"title":"JavaScript中的prototype属性","date":"2019-12-01T13:24:11.000Z","url":"/2019/12/01/JavaScript中的prototype属性/","tags":["JavaScript"],"content":"定义prototype 属性允许您向对象添加属性和方法，Prototype 是全局属性，并适用于所有的 Javascript 对象。用法object.prototype.name=value注意prototype属性是函数所独有的，由于在js中一切皆对象，函数也不例外，故这并非和其定义相矛盾。由来所有的实例对象都可以继承构造函数中的属性和方法,但是，在同一个对象的实例之间却无法共享属性。如下代码：为了解决构造函数的对象实例之间无法共享属性的缺点，js提供了prototype属性。如下代码："},{"title":"来自React的灵魂拷问","date":"2019-11-02T09:34:05.000Z","url":"/2019/11/02/来自React的灵魂拷问/","tags":["react"],"content":"什么是纯函数箭头函数的作用有无状态组件的区别React中的合成事件什么情况下应该使用引用（ref）React中如何创建表单受控和非受控组件的区别高阶组件是什么，怎么用什么是纯组件使用MVC有什么问题FluxRedux Reducer 以及数据流动"}]